# ============================================================
#  CODE-CREW POS System — .gitignore
# ============================================================

# ------------------------------------------------------------
#  SECRETS — never commit these
# ------------------------------------------------------------
.env
db_config.json

# ------------------------------------------------------------
#  Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ------------------------------------------------------------
#  User-uploaded files (face photos, product images)
# ------------------------------------------------------------
static/face_images/*.jpg
static/face_images/*.jpeg
static/face_images/*.png
static/product_images/*.jpg
static/product_images/*.jpeg
static/product_images/*.png

# ------------------------------------------------------------
#  Virtual environment
# ------------------------------------------------------------
venv/
env/
.venv/

# ------------------------------------------------------------
#  OS clutter
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
#  Editor / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo